# Video Agent Suite - Environment Variables
# Copy this file to .env and fill in your keys
# DO NOT commit .env to git!

# ============================================================
# Required: Alibaba Cloud (DashScope) API Key
# Get yours at: https://dashscope.console.aliyun.com/
# ============================================================
ALIBABA_API_KEY=your-alibaba-api-key-here

# ============================================================
# Required: Pexels API Key (for b-roll sourcing)
# Get yours at: https://www.pexels.com/api/
# ============================================================
PEXELS_API_KEY=your-pexels-api-key-here

# ============================================================
# Optional: Model Configuration
# Uncomment and change if you want different models
# ============================================================

# LLM Models (Alibaba only)
# LLM_MODEL=qwen3.7-max
# VISION_MODEL=qwen-vl-max

# Image/Video Generation (Alibaba only)
# IMAGE_MODEL=wan2.7-image-pro
# VIDEO_MODEL=wan2.7t2v

# TTS / ASR (Alibaba only — no Edge TTS or Whisper)
# TTS_MODEL=cosyvoice-v3-plus           # Primary TTS
# TTS_FALLBACK=qwen3-tts-instruct-flash  # Fallback TTS
# ASR_MODEL=fun-asr                      # Primary ASR (replaces Whisper)
# ASR_FALLBACK=fun-asr-realtime          # Fallback ASR

# ============================================================
# Optional: OpenAI-compatible fallback
# ============================================================
# OPENAI_API_KEY=your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================
# Optional: Custom paths
# ============================================================
# FFMPEG_BINARY=C:\path\to\ffmpeg.exe
# FFPROBE_BINARY=C:\path\to\ffprobe.exe
